@model Desafio1MVCGrupoWASP.Models.Departamento

@{
    ViewData["Title"] = "Detalles del departamento";
}

<h1>Details</h1>

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0"><i class="bi bi-building"></i> Detalles del Departamento</h4>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-4 text-muted">
                    Nombre del Departamento
                </dt>
                <dd class="col-sm-8 fw-bold">
                    @Html.DisplayFor(model => model.Nombre)
                </dd>

                <!-- Si tienes un campo Descripción en tu modelo, agrégalo aquí -->
                <dt class="col-sm-4 text-muted">
                    Descripción
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.Descripcion)
                </dd>
            </dl>
        </div>
        <div class="card-footer bg-light text-end">
            <!-- Si tienes el botón de "Ver Empleados", puedes dejarlo aquí -->
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary px-4">Editar</a>
            <a asp-action="Index" class="btn btn-outline-secondary px-4">Volver a la lista</a>
        </div>
    </div>
</div>