@model Desafio1MVCGrupoWASP.Models.Empleado

@{
    ViewData["Title"] = "Detalles del empleado";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="bi bi-person-badge"></i> Ficha del Empleado</h4>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-4 text-muted">
                    Nombre Completo
                </dt>
                <dd class="col-sm-8 fw-bold fs-5">
                    @Html.DisplayFor(model => model.Nombre)
                </dd>

                <dt class="col-sm-4 text-muted">
                    Fecha de Nacimiento
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.FechaNacimiento)
                </dd>

                <dt class="col-sm-4 text-muted">
                    Fecha de Contratación
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.FechaContratacion)
                </dd>

                <dt class="col-sm-4 text-muted">
                    Salario
                </dt>
                <dd class="col-sm-8 text-success fw-bold">
                    @Html.DisplayFor(model => model.Salario)
                </dd>

                <dt class="col-sm-4 text-muted">
                    Departamento
                </dt>
                <dd class="col-sm-8">
                    <!-- Aquí usamos la propiedad de navegación para mostrar el nombre directamente -->
                    <span class="badge bg-secondary fs-6">
                        @Html.DisplayFor(model => model.Departamento.Nombre)
                    </span>
                </dd>
            </dl>
        </div>
        <div class="card-footer bg-light text-end">
            <a asp-action="Edit" asp-route-id="@Model?.ID" class="btn btn-primary px-4">Editar</a>
            <a asp-action="Index" class="btn btn-outline-secondary px-4">Volver a la lista</a>
        </div>
    </div>
</div>